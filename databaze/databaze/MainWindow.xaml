<Window x:Class="databaze.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:databaze"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="10,10,5,10" CornerRadius="3">
            <DataGrid x:Name="dgAuta"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Značka" Binding="{Binding Znacka}" Width="*"/>
                    <DataGridTextColumn Header="Model" Binding="{Binding ModelAuta}" Width="*"/>
                    <DataGridTextColumn Header="Rok" Binding="{Binding RokVyroby}" Width="60"/>
                    <DataGridTextColumn Header="Karoserie" Binding="{Binding Karoserie}" Width="100"/>
                    <DataGridTextColumn Header="Výkon" Binding="{Binding VykonKw}" Width="60"/>
                    <DataGridCheckBoxColumn Header="Auto mate" Binding="{Binding MamVGrazi}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="5,10,10,10" CornerRadius="5" Padding="15">
            <StackPanel>
                <TextBlock Text="Evidence aut" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" />

                <TextBlock Text="Značka:" Margin="0,0,0,2" />
                <TextBox x:Name="txtZnacka" Margin="0,0,0,10" Height="22" />

                <TextBlock Text="Model:" Margin="0,0,0,2" />
                <TextBox x:Name="txtModel" Margin="0,0,0,10" Height="22" />

                <TextBlock Text="Rok výroby:" Margin="0,0,0,2" />
                <TextBox x:Name="txtRok" Margin="0,0,0,10" Height="22" />

                <TextBlock Text="Karoserie:" Margin="0,0,0,2" />
                <TextBox x:Name="txtKaroserie" Margin="0,0,0,10" Height="22" />

                <TextBlock Text="Výkon (kW):" Margin="0,0,0,2" />
                <TextBox x:Name="txtVykon" Margin="0,0,0,10" Height="22" />

                <CheckBox x:Name="chkGaraz" Content="Auto chcete" Margin="0,5,0,20" />

                <Button Content="Přidat auto" Height="30" Margin="0,0,0,10" Background="LightGray" />
                <Button Content="Načíst vybrané do formuláře" Height="30" Margin="0,0,0,10" Background="LightGray" />
                <Button Content="Upravit vybrané auto" Height="30" Margin="0,0,0,10" Background="LightGray" />
                <Button Content="Smazat vybrané auto" Height="30" Margin="0,0,0,10" Background="LightGray"/>
                <Button Content="Vyčistit formulář" Height="30" Margin="0,0,0,0" Background="LightGray" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
    